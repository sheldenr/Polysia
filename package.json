{
  "name": "polysia-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for Polysia (frontend + backend).",
  "license": "MIT",
  "workspaces": [
    "web",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --prefix web run dev",
    "dev:backend": "npm --prefix backend run start",
    "build": "npm --prefix web run build",
    "preview": "npm --prefix web run preview",
    "lint": "npm --prefix web run lint"
  },
  "engines": {
    "node": ">=18"
  }
}
